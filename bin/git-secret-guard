#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * git-secret-guard — pre-commit secret scanner for staged diff.
 *
 * Scans only added lines in staged changes (or a commit range) for
 * high-confidence secret patterns: Basic Auth URLs, Authorization headers,
 * private keys, env-like secrets.
 *
 * Usage:
 *   vendor/bin/git-secret-guard staged [options]
 *   vendor/bin/git-secret-guard scan-range <range> [options]
 *
 * Commands:
 *   staged        Scan staged changes (git diff --cached).
 *   scan-range    Scan a commit range (for CI / pre-push).
 *
 * Options:
 *   --config=<path>          Config file path (default: .secret-guard.json in repo root).
 *   --show-fingerprint       Show fingerprint for allowlisting.
 *   --no-color               Disable colored output.
 *   -h, --help               Show this help message.
 *
 * Exit codes:
 *   0  No secrets found.
 *   1  Potential secrets found.
 *   2  Scanner or config error.
 */

// ── Constants ──────────────────────────────────────────────────────────────

const EXIT_CLEAN = 0;
const EXIT_LEAKS = 1;
const EXIT_ERROR = 2;

// ── Main ───────────────────────────────────────────────────────────────────

function main(array $argv): int
{
    $args = parseArgs($argv);

    if ($args['help']) {
        printHelp();
        return EXIT_CLEAN;
    }

    if ($args['command'] === null) {
        fwrite(STDERR, 'Usage: git-secret-guard <staged|scan-range> [options]' . PHP_EOL);
        fwrite(STDERR, 'Run with --help for details.' . PHP_EOL);
        return EXIT_ERROR;
    }

    if ($args['command'] === 'scan-range' && $args['range'] === null) {
        fwrite(STDERR, 'Error: scan-range requires a revision range.' . PHP_EOL);
        fwrite(STDERR, 'Example: git-secret-guard scan-range origin/main...HEAD' . PHP_EOL);
        return EXIT_ERROR;
    }

    // Load config (optional file, no error if missing)
    $config = loadConfig($args['config']);

    // Acquire diff
    $diff = $args['command'] === 'staged'
        ? getStagedDiff()
        : getRangeDiff($args['range']);

    if ($diff === '') {
        echo 'git-secret-guard: nothing to scan.' . PHP_EOL;
        return EXIT_CLEAN;
    }

    // Parse added lines
    $addedLines = parseDiff($diff);

    if ($addedLines === []) {
        echo 'git-secret-guard: no added lines to scan.' . PHP_EOL;
        return EXIT_CLEAN;
    }

    // Match rules
    $rules = getRules();
    $findings = matchRules($addedLines, $rules);

    // Filter allowlisted
    $findings = filterAllowlisted($findings, $config);

    // Report
    if ($findings === []) {
        $c = $args['color'];
        echo 'git-secret-guard: no secrets found. ' . color('✓', '32', $c) . PHP_EOL;
        return EXIT_CLEAN;
    }

    printFindings($findings, $args);

    $c = $args['color'];
    fwrite(STDERR, PHP_EOL . color('Commit blocked.', '31;1', $c) . ' Remove secrets or add to allowlist.' . PHP_EOL);
    fwrite(STDERR, 'Config file: .secret-guard.json' . PHP_EOL);

    return EXIT_LEAKS;
}

// ── Argument parsing ───────────────────────────────────────────────────────

/**
 * @return array{command: string|null, range: string|null, config: string, showFingerprint: bool, color: bool, help: bool}
 */
function parseArgs(array $argv): array
{
    $result = [
        'command' => null,
        'range' => null,
        'config' => null,
        'showFingerprint' => false,
        'color' => true,
        'help' => false,
    ];

    foreach ($argv as $i => $arg) {
        if ($i === 0) {
            continue;
        }

        if ($arg === 'staged' || $arg === 'scan-range') {
            $result['command'] = $arg;
        } elseif (str_starts_with($arg, '--config=')) {
            $result['config'] = substr($arg, strlen('--config='));
        } elseif ($arg === '--show-fingerprint') {
            $result['showFingerprint'] = true;
        } elseif ($arg === '--no-color') {
            $result['color'] = false;
        } elseif ($arg === '--help' || $arg === '-h') {
            $result['help'] = true;
        } elseif (!str_starts_with($arg, '-')) {
            // Positional argument — range for scan-range
            if ($result['range'] === null) {
                $result['range'] = $arg;
            }
        }
    }

    // Respect NO_COLOR convention (https://no-color.org)
    if (getenv('NO_COLOR') !== false || getenv('TERM') === 'dumb') {
        $result['color'] = false;
    }

    // Default config path
    if ($result['config'] === null) {
        $root = getGitRoot();
        $result['config'] = $root . '/.secret-guard.json';
    }

    return $result;
}

// ── Help ───────────────────────────────────────────────────────────────────

function printHelp(): void
{
    echo <<<'HELP'
git-secret-guard — pre-commit secret scanner

Usage:
  vendor/bin/git-secret-guard staged [options]
  vendor/bin/git-secret-guard scan-range <range> [options]

Commands:
  staged        Scan staged changes (git diff --cached).
  scan-range    Scan a commit range (for CI / pre-push).

Options:
  --config=<path>          Config file (default: .secret-guard.json).
  --show-fingerprint       Show fingerprint for allowlisting.
  --no-color               Disable colored output.
  -h, --help               Show this help message.

Exit codes:
  0  No secrets found.
  1  Potential secrets found.
  2  Scanner or config error.

Detected patterns:
  basic-auth-url      HTTP(S) URL with user:password credentials
  auth-basic-header   Authorization: Basic header with credentials
  private-key         Private key header (RSA, EC, OpenSSH, etc.)
  env-secret          *_TOKEN=, *_SECRET=, *_PASSWORD=, API_KEY=

Allowlist config (.secret-guard.json):
  {
    "allowlist": [
      {
        "description": "Example URL in documentation",
        "path": "docs/api.md",
        "fingerprint": "sha256:abc123..."
      },
      {
        "description": "Test fixtures",
        "path": "tests/fixtures/*"
      }
    ]
  }

HELP;
}

// ── Git helpers ────────────────────────────────────────────────────────────

function getGitRoot(): string
{
    $output = [];
    $exitCode = 0;
    exec('git rev-parse --show-toplevel 2>/dev/null', $output, $exitCode);

    if ($exitCode !== 0 || $output === []) {
        fwrite(STDERR, 'Error: not in a git repository.' . PHP_EOL);
        exit(EXIT_ERROR);
    }

    return $output[0];
}

function getStagedDiff(): string
{
    $output = [];
    $exitCode = 0;
    exec('git diff --cached --unified=0 --no-ext-diff 2>/dev/null', $output, $exitCode);

    if ($exitCode !== 0) {
        fwrite(STDERR, 'Error: failed to get staged diff.' . PHP_EOL);
        exit(EXIT_ERROR);
    }

    return implode("\n", $output);
}

function getRangeDiff(string $range): string
{
    // Validate range format to prevent injection
    if (!preg_match('/^[a-zA-Z0-9._\/~^:@-]+$/', $range)) {
        fwrite(STDERR, "Error: invalid revision range: $range" . PHP_EOL);
        exit(EXIT_ERROR);
    }

    $output = [];
    $exitCode = 0;
    exec('git diff --unified=0 --no-ext-diff ' . escapeshellarg($range) . ' 2>/dev/null', $output, $exitCode);

    if ($exitCode !== 0) {
        fwrite(STDERR, "Error: failed to get diff for range: $range" . PHP_EOL);
        exit(EXIT_ERROR);
    }

    return implode("\n", $output);
}

// ── Config ─────────────────────────────────────────────────────────────────

/**
 * @return array{allowlist: list<array<string, string>>}
 */
function loadConfig(string $path): array
{
    if (!file_exists($path)) {
        return ['allowlist' => []];
    }

    $content = file_get_contents($path);
    if ($content === false) {
        fwrite(STDERR, "Warning: cannot read config file: $path" . PHP_EOL);
        return ['allowlist' => []];
    }

    $config = json_decode($content, true);
    if (json_last_error() !== JSON_ERROR_NONE) {
        fwrite(STDERR, "Error: invalid JSON in config file: $path" . PHP_EOL);
        fwrite(STDERR, '  ' . json_last_error_msg() . PHP_EOL);
        exit(EXIT_ERROR);
    }

    if (!is_array($config)) {
        fwrite(STDERR, "Error: config file must contain a JSON object: $path" . PHP_EOL);
        exit(EXIT_ERROR);
    }

    return array_merge(['allowlist' => []], $config);
}

// ── Diff parsing ───────────────────────────────────────────────────────────

/**
 * Parse unified diff into added lines.
 *
 * @return list<array{file: string, line: int, content: string}>
 */
function parseDiff(string $diff): array
{
    $result = [];
    $lines = explode("\n", $diff);
    $currentFile = null;
    $currentLine = 0;
    $inHunk = false;

    foreach ($lines as $line) {
        // File header: +++ b/filename
        if (str_starts_with($line, '+++ b/')) {
            $currentFile = substr($line, 6);
            $inHunk = false;
            continue;
        }

        // Deleted file: no added lines to scan
        if (str_starts_with($line, '+++ /dev/null')) {
            $currentFile = null;
            $inHunk = false;
            continue;
        }

        // Hunk header: @@ -old_start[,old_count] +new_start[,new_count] @@
        if (preg_match('/^@@[^+]*\+(\d+)/', $line, $m)) {
            $currentLine = (int) $m[1];
            $inHunk = true;
            continue;
        }

        // Added line (skip +++ file headers)
        if ($currentFile !== null && $inHunk && str_starts_with($line, '+') && !str_starts_with($line, '+++')) {
            $result[] = [
                'file' => $currentFile,
                'line' => $currentLine,
                'content' => substr($line, 1),
            ];
            $currentLine++;
        }
    }

    return $result;
}

// ── Rules ──────────────────────────────────────────────────────────────────

/**
 * @return list<array{id: string, pattern: string, description: string, severity: string}>
 */
function getRules(): array
{
    return [
        [
            'id' => 'basic-auth-url',
            'pattern' => '#https?://([^\s/:@]+):(\S+)@(\S+)#',
            'description' => 'Basic Auth URL with credentials',
            'severity' => 'high',
        ],
        [
            'id' => 'auth-basic-header',
            'pattern' => '/Authorization:\s*Basic\s+([A-Za-z0-9+\/]+=*)/i',
            'description' => 'Authorization Basic header with credentials',
            'severity' => 'high',
        ],
        [
            'id' => 'private-key',
            'pattern' => '/-----BEGIN[^\r\n]*PRIVATE\s+KEY/',
            'description' => 'Private key header',
            'severity' => 'high',
        ],
        [
            'id' => 'env-secret',
            'pattern' => '/\b([A-Za-z0-9_]*(?:TOKEN|SECRET|PASSWORD|API_KEY|APIKEY))\s*[=:]\s*["\']?([^\s"\'`,;]+)/i',
            'description' => 'Environment variable with secret value',
            'severity' => 'medium',
        ],
    ];
}

// ── Matching ───────────────────────────────────────────────────────────────

/**
 * @param list<array{file: string, line: int, content: string}> $addedLines
 * @param list<array{id: string, pattern: string, description: string, severity: string}> $rules
 * @return list<array{rule: string, severity: string, description: string, file: string, line: int, content: string, masked: string, fingerprint: string}>
 */
function matchRules(array $addedLines, array $rules): array
{
    $findings = [];

    foreach ($addedLines as $lineInfo) {
        foreach ($rules as $rule) {
            if (!preg_match($rule['pattern'], $lineInfo['content'], $matches)) {
                continue;
            }

            // Apply rule-specific false-positive filtering
            if (shouldSkip($rule['id'], $matches)) {
                continue;
            }

            $findings[] = [
                'rule' => $rule['id'],
                'severity' => $rule['severity'],
                'description' => $rule['description'],
                'file' => $lineInfo['file'],
                'line' => $lineInfo['line'],
                'content' => $lineInfo['content'],
                'masked' => maskContent($rule['id'], $lineInfo['content'], $matches),
                'fingerprint' => computeFingerprint($rule['id'], $lineInfo['file'], $lineInfo['content']),
            ];
        }
    }

    return $findings;
}

/**
 * Rule-specific filtering to reduce false positives.
 *
 * @param list<string> $matches
 */
function shouldSkip(string $ruleId, array $matches): bool
{
    return match ($ruleId) {
        'basic-auth-url' => isBasicAuthPlaceholder($matches[1] ?? '', $matches[2] ?? '', $matches[3] ?? ''),
        'auth-basic-header' => !isValidBasicAuth($matches[1] ?? ''),
        'env-secret' => isEnvPlaceholder($matches[2] ?? ''),
        default => false,
    };
}

// ── Placeholder detection ──────────────────────────────────────────────────

/**
 * Check if Basic Auth credentials are known placeholders (not real secrets).
 */
function isBasicAuthPlaceholder(string $user, string $pass, string $host): bool
{
    // Known placeholder hosts
    $placeholderHosts = [
        'example.com', 'example.org', 'example.net',
        'localhost', '127.0.0.1', '0.0.0.0',
        'test', 'dummy', 'placeholder',
    ];

    // Extract hostname (remove possible port and path)
    $hostClean = strtolower(preg_replace('#[:/].*$#', '', $host));

    foreach ($placeholderHosts as $ph) {
        if ($hostClean === $ph || str_ends_with($hostClean, '.' . $ph)) {
            return true;
        }
    }

    // Known placeholder credentials (both user AND pass must be placeholders)
    $userLower = strtolower($user);
    $passLower = strtolower($pass);

    $placeholderUsers = ['user', 'username', '<user>', 'your_user', 'youruser', 'your-user', 'xxx', 'foo'];
    $placeholderPasses = ['pass', 'password', '<password>', 'your_pass', 'yourpass', 'your-password', 'xxx', '***', 'changeme', 'bar', 'test'];

    return in_array($userLower, $placeholderUsers, true)
        && in_array($passLower, $placeholderPasses, true);
}

/**
 * Check if base64 value decodes to valid "user:password" format.
 */
function isValidBasicAuth(string $base64): bool
{
    $decoded = base64_decode($base64, true);
    if ($decoded === false) {
        return false;
    }

    // Basic Auth = "user:password", must contain ":" and be > 1 char
    return str_contains($decoded, ':') && strlen($decoded) > 1;
}

/**
 * Check if env-like value is a known placeholder (not a real secret).
 */
function isEnvPlaceholder(string $value): bool
{
    // Empty
    if (trim($value) === '') {
        return true;
    }

    // Variable references: $VAR, ${VAR}
    if (preg_match('/^\$\{?[A-Za-z_]\w*\}?$/', $value)) {
        return true;
    }

    // Template placeholders: <value>, <your-token>
    if (preg_match('/^<[^>]+>$/', $value)) {
        return true;
    }

    // Masked values: ****
    if (preg_match('/^\*+$/', $value)) {
        return true;
    }

    // Very short values (< 4 chars) — unlikely to be real secrets
    if (strlen($value) < 4) {
        return true;
    }

    // Common placeholder strings
    $lower = strtolower($value);
    $placeholders = [
        'changeme', 'change_me', 'change-me',
        'your_token_here', 'your_secret_here', 'your_password_here',
        'your_value', 'your_api_key', 'your_token', 'your_secret',
        'xxx', 'todo', 'fixme', 'placeholder', 'dummy', 'test', 'example',
        'insert_here', 'replace_me', 'replace_this',
        'n/a', 'na', 'null', 'none', 'false', 'true', 'yes', 'no',
        '...', 'redacted',
    ];

    return in_array($lower, $placeholders, true);
}

// ── Fingerprint ────────────────────────────────────────────────────────────

function computeFingerprint(string $ruleId, string $file, string $content): string
{
    return 'sha256:' . hash('sha256', $ruleId . ':' . $file . ':' . $content);
}

// ── Allowlist ──────────────────────────────────────────────────────────────

/**
 * Remove allowlisted findings.
 *
 * @param list<array{...}> $findings
 * @param array{allowlist: list<array<string, string>>} $config
 * @return list<array{...}>
 */
function filterAllowlisted(array $findings, array $config): array
{
    $allowlist = $config['allowlist'] ?? [];

    return array_values(array_filter(
        $findings,
        static function (array $finding) use ($allowlist): bool {
            foreach ($allowlist as $entry) {
                // Exact fingerprint match
                if (isset($entry['fingerprint']) && $entry['fingerprint'] === $finding['fingerprint']) {
                    return false; // allowed
                }

                // Path glob match (all rules for matching files)
                if (isset($entry['path']) && !isset($entry['fingerprint'])) {
                    if (fnmatch($entry['path'], $finding['file'])) {
                        return false; // allowed
                    }
                }

                // Path + rule match
                if (isset($entry['path'], $entry['rule'])) {
                    if (fnmatch($entry['path'], $finding['file']) && $entry['rule'] === $finding['rule']) {
                        return false; // allowed
                    }
                }
            }

            return true; // keep
        },
    ));
}

// ── Masking ────────────────────────────────────────────────────────────────

/**
 * Mask secret value in content for safe display.
 *
 * @param list<string> $matches
 */
function maskContent(string $ruleId, string $content, array $matches): string
{
    if ($ruleId === 'basic-auth-url') {
        $user = $matches[1] ?? '';
        $pass = $matches[2] ?? '';
        if ($user !== '' && $pass !== '') {
            $userQ = preg_quote($user, '/');
            $passQ = preg_quote($pass, '/');
            $masked = preg_replace(
                "#(https?://){$userQ}:{$passQ}@#",
                '$1***:***@',
                $content,
            );
            if ($masked !== null) {
                return $masked;
            }
        }
        // Fallback: generic mask
        $masked = preg_replace(
            '#(https?://)[^\s/:@]+:[^\s@]+(@\S+)#',
            '$1***:***$2',
            $content,
        );

        return $masked ?? $content;
    }

    if ($ruleId === 'auth-basic-header') {
        $masked = preg_replace(
            '/(Authorization:\s*Basic\s+)[A-Za-z0-9+\/=]+/i',
            '$1***',
            $content,
        );

        return $masked ?? $content;
    }

    if ($ruleId === 'private-key') {
        // Header line doesn't contain the secret itself
        return $content;
    }

    if ($ruleId === 'env-secret') {
        return maskEnvValue($content, $matches[1] ?? '', $matches[2] ?? '');
    }

    return $content;
}

function maskEnvValue(string $content, string $varName, string $value): string
{
    if ($varName === '' || $value === '') {
        return $content;
    }

    $varQuoted = preg_quote($varName, '/');
    $valQuoted = preg_quote($value, '/');

    $masked = preg_replace(
        "/({$varQuoted}\s*[=:]\s*['\"]?){$valQuoted}/i",
        '$1***',
        $content,
    );

    return $masked ?? $content;
}

// ── Output ─────────────────────────────────────────────────────────────────

/**
 * @param list<array{rule: string, severity: string, description: string, file: string, line: int, content: string, masked: string, fingerprint: string}> $findings
 * @param array{showFingerprint: bool, color: bool} $args
 */
function printFindings(array $findings, array $args): void
{
    $c = $args['color'];
    $count = count($findings);

    fwrite(STDERR, color("git-secret-guard: found $count potential secret(s):", '31;1', $c) . PHP_EOL);
    fwrite(STDERR, PHP_EOL);

    foreach ($findings as $i => $f) {
        $num = $i + 1;

        fwrite(STDERR, '  ' . color("[{$num}] {$f['rule']}", '33;1', $c) . ' (' . $f['severity'] . ')' . PHP_EOL);
        fwrite(STDERR, "      File:   {$f['file']}:{$f['line']}" . PHP_EOL);
        fwrite(STDERR, "      Match:  {$f['masked']}" . PHP_EOL);

        if ($args['showFingerprint']) {
            fwrite(STDERR, "      Fingerprint: {$f['fingerprint']}" . PHP_EOL);
        }

        fwrite(STDERR, PHP_EOL);
    }
}

function color(string $text, string $code, bool $enabled): string
{
    return $enabled ? "\033[{$code}m{$text}\033[0m" : $text;
}

// ── Run ────────────────────────────────────────────────────────────────────

exit(main($argv));
