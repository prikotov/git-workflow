#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * git-workflow-init — copy git workflow documentation into the project.
 *
 * Usage:
 *   php vendor/bin/git-workflow-init [target-dir] [--docs-path=<path>] [--hooks] [--force]
 *
 *   target-dir   — project root (default: current working directory).
 *   --docs-path  — relative path where docs will be copied (default: docs/git-workflow/).
 *   --hooks      — install git hooks (commit-msg, pre-commit) into .git/hooks/.
 *   --force      — overwrite existing files with fresh copies from the package.
 */

// ── Parse arguments ────────────────────────────────────────────────────────

$force     = false;
$hooks     = false;
$targetArg = null;
$docsPath  = null;

foreach ($argv as $i => $arg) {
    if ($i === 0) {
        continue;
    }
    if ($arg === '--force') {
        $force = true;
    } elseif ($arg === '--hooks') {
        $hooks = true;
    } elseif (str_starts_with($arg, '--docs-path=')) {
        $docsPath = substr($arg, strlen('--docs-path='));
    } else {
        $targetArg = $arg;
    }
}

// ── Resolve paths ──────────────────────────────────────────────────────────

$packageRoot = dirname(__DIR__);
$targetDir   = $targetArg !== null ? realpath($targetArg) : getcwd();

if ($targetDir === false || !is_dir($targetDir)) {
    fwrite(STDERR, "Error: target directory does not exist: " . ($targetArg ?? getcwd()) . PHP_EOL);
    exit(1);
}

$sourceDocs = $packageRoot . '/docs/git-workflow';
$docsPath   = $docsPath ?? 'docs/git-workflow';
$targetDocs = $targetDir . '/' . $docsPath;

if (!is_dir($sourceDocs)) {
    fwrite(STDERR, "Error: package docs/ not found at $sourceDocs" . PHP_EOL);
    exit(1);
}

if ($force) {
    echo "  ⚠  --force: existing files will be overwritten." . PHP_EOL;
}

// ── Copy docs ──────────────────────────────────────────────────────────────

$copied   = 0;
$skipped  = 0;
$updated  = 0;
$iterator = new RecursiveIteratorIterator(
    new RecursiveDirectoryIterator($sourceDocs, RecursiveDirectoryIterator::SKIP_DOTS),
    RecursiveIteratorIterator::SELF_FIRST,
);

foreach ($iterator as $item) {
    $relativePath = substr($item->getPathname(), strlen($sourceDocs) + 1);
    $targetPath   = $targetDocs . '/' . $relativePath;

    if ($item->isDir()) {
        if (!is_dir($targetPath)) {
            mkdir($targetPath, 0755, true);
        }
        continue;
    }

    if (file_exists($targetPath)) {
        if ($force) {
            copy($item->getPathname(), $targetPath);
            echo "  Updated  $docsPath/$relativePath" . PHP_EOL;
            $updated++;
        } else {
            echo "  Skip     $docsPath/$relativePath (already exists)" . PHP_EOL;
            $skipped++;
        }
        continue;
    }

    $targetDirForFile = dirname($targetPath);
    if (!is_dir($targetDirForFile)) {
        mkdir($targetDirForFile, 0755, true);
    }

    copy($item->getPathname(), $targetPath);
    echo "  Copied   $docsPath/$relativePath" . PHP_EOL;
    $copied++;
}

// ── Create docs/releases/ with .gitkeep ───────────────────────────────────

$releasesDir = $targetDir . '/docs/releases';
if (!is_dir($releasesDir)) {
    mkdir($releasesDir, 0755, true);
    echo "  Created  docs/releases/" . PHP_EOL;
}
$gitkeep = $releasesDir . '/.gitkeep';
if (!file_exists($gitkeep)) {
    file_put_contents($gitkeep, '');
    echo "  Created  docs/releases/.gitkeep" . PHP_EOL;
}

// ── Update .gitignore ─────────────────────────────────────────────────────

$gitignore     = $targetDir . '/docs/.gitignore';
$gitignoreDir  = dirname($docsPath) === 'docs' ? basename($docsPath) . '/' : $docsPath;
$entry         = $gitignoreDir;

if (file_exists($gitignore)) {
    $content = file_get_contents($gitignore);
    if (!str_contains($content, $entry)) {
        $content = rtrim($content) . PHP_EOL . $entry . PHP_EOL;
        file_put_contents($gitignore, $content);
        echo "  Updated docs/.gitignore (+ $entry)" . PHP_EOL;
    }
} else {
    if (!is_dir(dirname($gitignore))) {
        mkdir(dirname($gitignore), 0755, true);
    }
    file_put_contents($gitignore, $entry . PHP_EOL);
    echo "  Updated docs/.gitignore (+ $entry)" . PHP_EOL;
}

// ── Install hooks ─────────────────────────────────────────────────────────

$hooksInstalled = 0;
$hooksSkipped   = 0;

if ($hooks) {
    $sourceHooks = $packageRoot . '/hooks';
    $targetHooks = $targetDir . '/.git/hooks';

    if (!is_dir($sourceHooks)) {
        fwrite(STDERR, "  Warning: hooks/ directory not found in package." . PHP_EOL);
    } elseif (!is_dir($targetHooks)) {
        fwrite(STDERR, "  Warning: .git/hooks/ not found at $targetHooks." . PHP_EOL);
        fwrite(STDERR, '  Make sure you are in a git repository.' . PHP_EOL);
    } else {
        $hookFiles = glob($sourceHooks . '/*');
        if ($hookFiles === []) {
            fwrite(STDERR, '  Warning: no hook templates found in package hooks/.' . PHP_EOL);
        }

        foreach ($hookFiles as $hookFile) {
            if (!is_file($hookFile)) {
                continue;
            }

            $hookName    = basename($hookFile);
            $targetHook  = $targetHooks . '/' . $hookName;

            if (file_exists($targetHook) && !$force) {
                echo "  Skip     .git/hooks/$hookName (already exists)" . PHP_EOL;
                $hooksSkipped++;
                continue;
            }

            copy($hookFile, $targetHook);
            chmod($targetHook, 0755);

            $action = file_exists($targetHook) && !$force ? 'Copied' : 'Installed';
            if ($force && file_exists($targetHook)) {
                $action = 'Updated';
            }
            echo "  $action  .git/hooks/$hookName" . PHP_EOL;
            $hooksInstalled++;
        }
    }
}

// ── Summary ────────────────────────────────────────────────────────────────

echo PHP_EOL;
echo "Done. $copied copied, $updated updated, $skipped skipped." . PHP_EOL;
if ($hooks) {
    echo "Hooks: $hooksInstalled installed, $hooksSkipped skipped." . PHP_EOL;
}
echo PHP_EOL;
echo "Next steps:" . PHP_EOL;
echo "  1. Add these lines to your project's AGENTS.md:" . PHP_EOL;
echo "     * Коммиты — [$docsPath/commits.md]($docsPath/commits.md)." . PHP_EOL;
echo "     * Pull Requests — [$docsPath/pull-request.md]($docsPath/pull-request.md)." . PHP_EOL;

if (!$hooks) {
    echo PHP_EOL;
    echo 'To install git hooks (commit-msg, pre-commit):' . PHP_EOL;
    echo '  php vendor/bin/git-workflow-init --hooks' . PHP_EOL;
}
