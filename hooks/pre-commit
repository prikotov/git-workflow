#!/usr/bin/env bash
set -euo pipefail

# ── Pre-commit hook: scan staged diff for secrets via Gitleaks ─────────────
#
# Install:
#   php vendor/bin/git-workflow-init --hooks
#
# Requirements:
#   Gitleaks must be installed: https://github.com/gitleaks/gitleaks
#
# Skip temporarily:
#   git commit --no-verify
#
# Note: --no-verify bypasses this hook. Use pre-push or CI as a second layer.

if ! command -v gitleaks &>/dev/null; then
    echo "gitleaks: skipping (not installed). See https://github.com/gitleaks/gitleaks"
    exit 0
fi

gitleaks protect --staged
